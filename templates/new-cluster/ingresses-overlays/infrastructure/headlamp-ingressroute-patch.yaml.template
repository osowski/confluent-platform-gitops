---
apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: headlamp
  namespace: headlamp
spec:
  entryPoints:
    - websecure
  routes:
    - match: Host(`headlamp.$CLUSTER_NAME.$DOMAIN`)
      kind: Rule
      services:
        - name: headlamp
          port: 80
          scheme: http
  tls:
    secretName: headlamp-tls
